# Backend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT  →  Copy this file to .env and fill in values
# RAILWAY PRODUCTION →  Add these as Environment Variables in Railway dashboard
# ─────────────────────────────────────────────────────────────────────────────

# ─── SERVER ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── DATABASE (Neon PostgreSQL) ───────────────────────────────────────────────
# Get from: neon.tech → Your Project → Connection String
# Format:   postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# ─── REDIS (Upstash) ──────────────────────────────────────────────────────────
# Get from: upstash.com → Your Database → Redis Details
# Use the "rediss://" TLS URL
# Format:   rediss://default:xxxxxxxx@global-xxxxx.upstash.io:6379
REDIS_URL=rediss://default:xxxxxxxx@global-xxxxx.upstash.io:6379

# ─── JWT SECRETS ─────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Run TWICE — different values for access and refresh
JWT_ACCESS_SECRET=generate_64_byte_hex_string_here
JWT_REFRESH_SECRET=generate_different_64_byte_hex_string_here

# ─── WEBAUTHN ────────────────────────────────────────────────────────────────
# Set to your Vercel domain (without https://)
WEBAUTHN_RP_ID=your-app.vercel.app
WEBAUTHN_ORIGIN=https://your-app.vercel.app

# ─── CORS ────────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=https://your-app.vercel.app

# ─── RAZORPAY (Phase 2) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── BSE STAR MF (Phase 2) ───────────────────────────────────────────────────
BSE_MEMBER_CODE=your_bse_member_code
BSE_USER_ID=your_bse_user_id
BSE_PASSWORD=your_bse_password
BSE_API_URL=https://bsestarmf.in/api

# ─── EMAIL / SMS (Phase 2) ───────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxx
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── EMAIL (SENDGRID) ─────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@bluesparrow.in

# ─── AWS S3 (Document Storage) ────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=blue-sparrow-kyc-docs

# ─── FRONTEND URL ─────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── ENCRYPTION ───────────────────────────────────────────
ENCRYPTION_KEY=your_32_char_aes256_encryption_key_here
